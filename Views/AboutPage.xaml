<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiProject.ViewModels"
             x:DataType="vm:AboutViewModel"
             x:Class="MauiProject.Views.AboutPage"
             Title="MAUI Image Gallery"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,20"
            Spacing="20"
            VerticalOptions="Fill">

            <Image
                Source="dotnet_bot.png"
                HeightRequest="200"
                Aspect="AspectFit"
                Margin="0,20,0,0"/>

            <Label
                Text="{Binding AppName}"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1"
                HorizontalTextAlignment="Center"/>

            <Label
                Text="{Binding AppDescription}"
                HorizontalTextAlignment="Center"
                FontSize="14"
                TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"/>

            <Frame
                Padding="20"
                Margin="0,20,0,0"
                BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                CornerRadius="8">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Version"
                        FontAttributes="Bold"
                        FontSize="14"/>
                    <Label
                        Text="{Binding AppVersion}"
                        FontSize="12"
                        TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"/>
                </VerticalStackLayout>
            </Frame>

            <Frame
                Padding="20"
                Margin="0,10,0,0"
                BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                CornerRadius="8">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Info"
                        FontAttributes="Bold"
                        FontSize="14"/>
                    <Label
                        Text="{Binding DeveloperInfo}"
                        FontSize="12"
                        TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"/>
                </VerticalStackLayout>
            </Frame>

            <Label
                Text="© 2026 Patrick Varkoi"
                HorizontalTextAlignment="Center"
                FontSize="12"
                TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                Margin="0,30,0,20"/>

            <Button
                Text="Back"
                Command="{Binding GoBackCommand}"
                HorizontalOptions="Fill"
                MaximumWidthRequest="150"
                Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
